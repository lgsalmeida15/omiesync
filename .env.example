# =============================================================
# omie-sync-api — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env com valores reais.
# =============================================================

# --- Banco de dados ---
# Em produção/HML, use o nome do serviço Postgres na rede interna do Coolify
DATABASE_URL=postgres://postgres:senha_segura@postgres:5432/omie_sync?sslmode=disable

# --- Autenticação JWT ---
# Mínimo 32 caracteres aleatórios — gere com: openssl rand -hex 32
JWT_SECRET=troque-por-string-aleatoria-de-minimo-32-caracteres

# --- Servidor ---
PORT=8080
APP_ENV=production
LOG_LEVEL=info

# --- Concorrência de workers ETL ---
WORKER_MAX_CONCURRENT=20

# --- CORS ---
# URL pública do frontend (sem barra no final)
CORS_ORIGIN=https://hml-front-omiesync.otmiz.tech

# =============================================================
# URLs do ambiente HML (referência — não lidas pela aplicação)
# Frontend : https://hml-front-omiesync.otmiz.tech
# Backend  : https://hml-back-omiesync.otmiz.tech
# =============================================================
