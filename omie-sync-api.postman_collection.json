            "url": {
              "raw": "{{base_url}}/dados/{{empresa_id}}/contas-correntes?page=1&per_page=100",
              "host": ["{{base_url}}"],
              "path": ["dados", "{{empresa_id}}", "contas-correntes"],
              "query": [
                { "key": "page",     "value": "1" },
                { "key": "per_page", "value": "100" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Contas a Pagar",
          "request": {
            "method": "GET",
            "url": {
