    {
      "name": "🚀 Fluxo Completo ETL (E2E)",
      "description": "Execute nesta ordem para testar o fluxo completo — do cadastro até os dados sincronizados.\n\n1. Login\n2. Criar Grupo → schema provisionado automaticamente\n3. Criar Empresa (com credenciais Omie reais)\n4. Configurar Sync\n5. Forçar Sync Full\n6. Ver Status (aguardar job=concluido)\n7. Consultar Clientes\n8. Criar Usuário\n9. Conceder Permissão\n10. Verificar Audit Logs",
      "item": [
        {
          "name": "1. Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json().data;",
                  "pm.collectionVariables.set('access_token',  data.access_token);",
                  "pm.collectionVariables.set('refresh_token', data.refresh_token);",
                  "pm.test('Login OK', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@omie.local\",\n  \"password\": \"admin123\"\n}" }
          }
        },
        {
          "name": "2. Criar Grupo",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    pm.collectionVariables.set('grupo_id', pm.response.json().data.id);",
                  "    pm.test('Grupo criado + schema provisionado', () => pm.response.to.have.status(201));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/admin/grupos",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"nome\": \"Minha Empresa\",\n  \"slug\": \"minha-empresa\"\n}" }
          }
        },
        {
          "name": "3. Criar Empresa (credenciais Omie)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    pm.collectionVariables.set('empresa_id', pm.response.json().data.id);",
                  "    pm.test('Empresa criada', () => pm.response.to.have.status(201));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/admin/grupos/{{grupo_id}}/empresas",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"nome\": \"Minha Empresa Ltda\",\n  \"cnpj\": \"00.000.000/0001-00\",\n  \"app_key\": \"SEU_APP_KEY_AQUI\",\n  \"app_secret\": \"SEU_APP_SECRET_AQUI\"\n}" }
          }
        },
        {
          "name": "4. Configurar Sync (60 min)",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/sync/{{empresa_id}}/configurar",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"ativo\": true,\n  \"intervalo_min\": 60\n}" }
          }
        },
        {
          "name": "5. Forçar Sync Full (primeiro sync)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/sync/{{empresa_id}}/forcar",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"tipo\": \"full\"\n}" },
            "description": "Full sync para o primeiro uso — busca todos os registros do Omie."
          }
        },
        {
          "name": "6. Ver Status do Sync",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/sync/{{empresa_id}}/status",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "description": "Verifique status do último job. Aguarde status=concluido antes de consultar /dados."
          }
        },
        {
          "name": "7. Consultar Clientes Sincronizados",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/dados/{{empresa_id}}/clientes?page=1&per_page=50",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "8. Consultar Contas a Pagar",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/dados/{{empresa_id}}/contas-pagar?page=1&per_page=50",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "9. Criar Usuário do Cliente",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    pm.collectionVariables.set('usuario_id', pm.response.json().data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/admin/grupos/{{grupo_id}}/usuarios",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"nome\": \"Analista Financeiro\",\n  \"email\": \"financeiro@empresa.com\",\n  \"password\": \"senha1234\",\n  \"role\": \"viewer\"\n}" }
          }
        },
        {
          "name": "10. Conceder Acesso ao Dashboard",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/admin/permissoes/grant",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"usuario_id\": \"{{usuario_id}}\",\n  \"empresa_id\": \"{{empresa_id}}\",\n  \"recurso\": \"dashboard\",\n  \"acao\": \"ver\"\n}" }
          }
        }
      ]
    }
  ]
